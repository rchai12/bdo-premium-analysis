# BDO Market Tracker - Production Environment Variables
# Copy to .env and fill in real values

ConnectionStrings__DefaultConnection=Host=YOUR_NEON_HOST;Database=bdo_market;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
Jwt__Key=YOUR_JWT_SECRET_KEY_AT_LEAST_32_CHARS
Admin__Email=admin@yourdomain.com
Admin__Password=YOUR_ADMIN_PASSWORD
Cors__AllowedOrigins__0=https://your-cloudflare-pages-domain.pages.dev
