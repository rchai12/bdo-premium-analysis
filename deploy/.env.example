# BDO Market Tracker - Production Environment Variables
# Copy to .env and fill in real values

# Local PostgreSQL (runs in Docker alongside the API)
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
ConnectionStrings__DefaultConnection=Host=postgres;Database=bdo_market;Username=bdo;Password=YOUR_POSTGRES_PASSWORD

Jwt__Key=YOUR_JWT_SECRET_KEY_AT_LEAST_32_CHARS
Admin__Email=admin@yourdomain.com
Admin__Password=YOUR_ADMIN_PASSWORD
Cors__AllowedOrigins__0=https://your-cloudflare-pages-domain.pages.dev
